NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# REQUIRED — server-only service role key.
# Used by /api/admin/users (create employees) and /api/me/bootstrap (auto-create profile on first login).
# Get it from Supabase Dashboard → Project Settings → API → service_role key.
# NEVER expose this client-side. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Required for AI extraction (single-doc + bulk). Uses gemini-2.5-flash
# via @google/genai. Get a key at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Optional — only used by /api/ai/generate-template (not extraction).
ANTHROPIC_API_KEY=
